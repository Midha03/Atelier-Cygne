<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or "Atelier Cygne" }} — Atelier Cygne</title>
<meta name="description" content="{{ description or "Atelier Cygne is a monthly journal on interior design and architecture." }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,400..500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="site-header">
  <div class="header-row">
    <a href="/" class="wordmark">
      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M30 96C30 72 24 56 35 40C43 29 40 18 53 15C60 13 64 17 61 23C58 28 51 26 51 26" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        <path d="M14 94C40 105 76 105 96 84C101 79 98 73 90 75C69 81 39 81 28 93" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      </svg>
      <span>Atelier Cygne<span class="sub">Design &amp; Architecture Journal</span></span>
    </a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <svg width="22" height="16" viewBox="0 0 22 16"><path d="M0 1H22M0 8H22M0 15H22" stroke="#1B1A16" stroke-width="1.4"/></svg>
    </button>
    <nav class="main-nav">
      <a href="/" {% if page.url == "/" %}class="active"{% endif %}>Latest</a>
      <a href="/archive/" {% if page.url == "/archive/" %}class="active"{% endif %}>Editions</a>
      <a href="/about/" {% if page.url == "/about/" %}class="active"{% endif %}>About</a>
      <a href="/#subscribe">Subscribe</a>
    </nav>
  </div>
</header>

<main>
{{ content | safe }}
</main>

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/" class="wordmark" style="margin-bottom:6px;">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M30 96C30 72 24 56 35 40C43 29 40 18 53 15C60 13 64 17 61 23C58 28 51 26 51 26" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <path d="M14 94C40 105 76 105 96 84C101 79 98 73 90 75C69 81 39 81 28 93" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <span>Atelier Cygne</span>
        </a>
        <p style="max-width:32ch; color:var(--ink-soft); font-size:14px; margin-top:14px;">A monthly journal of interior design and architecture.</p>
      </div>
      <div>
        <h4>Read</h4>
        <ul>
          <li><a href="/">Latest Edition</a></li>
          <li><a href="/archive/">Full Archive</a></li>
        </ul>
      </div>
      <div>
        <h4>Journal</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/#subscribe">Subscribe</a></li>
        </ul>
      </div>
      <div>
        <h4>Elsewhere</h4>
        <ul>
          <li><a href="https://www.instagram.com/ateliercygne_/" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="mailto:hello@ateliercygne.com">hello@ateliercygne.com</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Atelier Cygne. All rights reserved.</span>
      <span>Published monthly since March 2026.</span>
    </div>
  </div>
</footer>

<script src="/js/script.js"></script>
</body>
</html>
